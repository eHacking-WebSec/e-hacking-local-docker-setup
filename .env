# ---------------------------------------------------------------------------
# eHacking offline-training local setup. All hosts are *.localhost (resolve
# to 127.0.0.1) and TLS is issued by the bundled step-ca — no internet, no
# Let's Encrypt, no DNS. Flags stay at their dummy defaults on purpose:
# every training laptop is identical.
# ---------------------------------------------------------------------------

# Module hostnames. The catcher runs ON the bare attacker host (single source
# of truth = ATTACKER_HOST); the catcher container's CATCHER_HOST is derived
# from it in docker-compose.yml so the app's salt-resolution host matches the
# host Traefik actually serves it on.
ATTACKER_HOST=attacker.localhost
HOST1=e-hacking.localhost
HOST2=www.e-hacking.localhost
IDP_HOST=idp.localhost
JSON_HOST=json.localhost
REST_HOST=rest.localhost
RS_HOST=rs.localhost
SOAP_HOST=soap.localhost
SP_HOST=sp.localhost
SPA_HOST=spa.localhost
WEBSEC_HOST=websec.localhost
XML_HOST=xml.localhost

# Module base paths (WildFly context roots inside the all-in-one image)
BASE_PATH_OIDC_IDP=/oidc_idp
BASE_PATH_OIDC_SP=/oidc_sp
BASE_PATH_REST=/rest-api-sec
BASE_PATH_SAML_IDP=/idp
BASE_PATH_SAML_SP=/sp
BASE_PATH_WEBSEC=/websec
BASE_PATH_JSON=/json-sec

# Ports (standard 80/443 on the training laptop)
PORT_HTTP=80
PORT_HTTPS=443

# Fixed project name so Traefik's docker provider can be scoped to THIS stack
# (see the constraint in the traefik service) — otherwise its provider watches
# every container on the host socket and same-named routers from another stack
# collide.
COMPOSE_PROJECT_NAME=ehacking-offline

# All-in-one image
DOCKER_REGISTRY=ghcr.io/ehacking-websec/ehacking
VARIANT="main"

# Catcher — open (passwordless) signup is fine offline; instructor/superuser
# areas use the well-known "student" password.
# Single-user mode: the catcher runs as ONE implicit instance on the bare
# attacker.localhost (no salt subdomain), so /signup auto-issues the token and
# the OIDC malicious-IdP flow targets attacker.localhost directly — sidestepping
# the salt-subdomain DNS resolution that's unsolved for the offline network.
# (Requires a catcher image that includes the CATCHER_SINGLE_USER feature.)
CATCHER_SINGLE_USER=true
CATCHER_ENABLE_API=false
CATCHER_OPEN_SIGNUP=true
CATCHER_INSTRUCTOR_PASSWORD=student
CATCHER_SUPERUSER_PASSWORD=student
CATCHER_INSTANCE_TTL_DAYS=30
CATCHER_MAX_BODY_BYTES=1048576
CATCHER_MAX_REQUESTS_PER_SALT=10000
CATCHER_URL_STYLE=subdomain

# Victim-bot report rate limit (per minute). Generous offline.
BOT_REPORT_RATE_LIMIT=60
